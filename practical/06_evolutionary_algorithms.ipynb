       "\n",
       ">>> import warnings\n",
       ">>> with warnings.catch_warnings(record=True) as warns:\n",
       "...     es = cma.CMAEvolutionStrategy(5 * [3], 0.1,\n",
       "...                 {\"transformation\": [lambda x: x**2+1.2, None],\n",
