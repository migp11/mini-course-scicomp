   "source": [
    "import numpy as np\n",
    "\n",
    "import cma"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0c055f10",
   "metadata": {},
   "outputs": [],
   "source": [
    "# función de ejemplo (parábola)\n",
    "def objective(x):\n",
    "    return (x[0] - 3)**2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e84205aa",
   "metadata": {},
   "outputs": [],
   "source": [
    "es = cma.CMAEvolutionStrategy([0], 1.0)\n",
    "\n",
    "res = es.optimize(objective, iterations=20)\n",
    "\n",
    "print(\"Best solution:\", res.result.xbest)"
   ]
  }
 ],
